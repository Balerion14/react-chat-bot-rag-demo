      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aM",
      "roundness": null,
      "seed": 877174170,
      "version": 79,
      "versionNonce": 1107639066,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776102720716,
      "link": null,
      "locked": false,
      "text": "Stocke les informations de réservation (nom du client, dates, langue).\nDonne le contexte du séjour.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Stocke les informations de réservation (nom du client, dates, langue).\nDonne le contexte du séjour.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "zjBVtz8bOevDA_mdTYO6J",
      "type": "text",
      "x": -980.7059849330344,
      "y": 1826.8215760730554,
      "width": 1550.4833984375,
      "height": 270,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aN",
      "roundness": null,
      "seed": 1764021274,
      "version": 266,
      "versionNonce": 861931782,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1776102999109,
      "link": null,
      "locked": false,
      "text": "Contient les informations liées à ce logement et utilisées pour répondre aux questions du client.\nChaque information est classée par catégorie (wifi, parking, check-in, etc.).\n\nExemple :\n    Catégorie : wifi\n    Contenu : Le mot de passe wifi est 12345678",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Contient les informations liées à ce logement et utilisées pour répondre aux questions du client.\nChaque information est classée par catégorie (wifi, parking, check-in, etc.).\n\nExemple :\n    Catégorie : wifi\n    Contenu : Le mot de passe wifi est 12345678",
      "autoResize": true,
      "lineHeight": 1.25
    },
