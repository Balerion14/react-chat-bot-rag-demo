    {
      "id": "PWrC-dcaEbuk4cd0aSuuZ",
      "type": "text",
      "x": -1710.4642857142844,
      "y": 89.82151503789919,
      "width": 1119.8155517578125,
      "height": 90,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "#a5d8ff",
      "fillStyle": "solid",
      "strokeWidth": 4,
